EXPORTS
    ; === Shared base operations (kriging_capi_common) ===
    ; Used by both Kriging and SpaceTimeKriging Python classes.

    ; --- Error / stats ---
    krige_get_last_error
    krige_solver_stats

    ; --- Observations (base) ---
    krige_update_obs_value
    krige_set_obs_drift
    krige_set_nscore

    ; --- Grid (base) ---
    krige_set_grid_cv

    ; --- Solve lifecycle (base) ---
    krige_prepare
    krige_solve

    ; --- Results (base) ---
    krige_get_nblocks
    krige_get_nsim
    krige_get_block_coord
    krige_get_estimate
    krige_get_estimate_all
    krige_get_variance
    krige_get_variance_all
    krige_to_str

    ; --- Persistent factorisation cache (base) ---
    krige_get_factor_info
    krige_get_factor_matrices
    krige_get_factor_system

    ; --- Weight store (base) ---
    krige_free_weight_store
    krige_get_weight_dims
    krige_get_weight_nnear
    krige_get_weight_inear
    krige_get_weight_data
    krige_get_weight_var
    krige_set_weights

    ; === Spatial kriging (kriging_capi) ===

    ; --- Lifecycle ---
    krige_create
    krige_destroy
    krige_initialize

    ; === Indicator kriging / SIS (kriging_capi) ===
    ; All other setup/solve/results functions are shared with spatial kriging.

    ; --- Lifecycle ---
    krige_ind_create

    ; --- Configuration ---
    krige_ind_set_ncat

    ; --- Observations ---
    krige_set_obs

    ; --- Variogram ---
    krige_reset_vgm
    krige_set_vgm
    krige_set_vgm_block

    ; --- Grid ---
    krige_set_grid
    krige_set_grid_block
    krige_set_grid_drift

    ; --- Simulation (SGSIM) ---
    krige_set_sim

    ; --- Gradient constraints ---
    krige_set_grad

    ; --- Search ---
    krige_set_search

    ; --- Threads ---
    krige_get_max_threads
    krige_get_num_threads

    ; === Space-time kriging (kriging_st_capi) ===

    ; --- Lifecycle ---
    krige_st_create
    krige_st_destroy
    krige_st_initialize

    ; --- ST model ---
    krige_st_set_st_model

    ; --- Observations ---
    krige_st_set_obs
    krige_st_set_grad

    ; --- Variogram ---
    krige_st_reset_vgm
    krige_st_set_vgm
    krige_st_set_vgm_temporal
    krige_st_set_vgm_joint_sills

    ; --- Grid ---
    krige_st_set_grid
    krige_st_set_grid_block
    krige_st_set_grid_drift

    ; --- Simulation (SGSIM) ---
    krige_st_set_sim

    ; --- Search ---
    krige_st_set_search

    ; --- Threads ---
    krige_st_get_max_threads
    krige_st_get_num_threads
